# ─── Supabase (read-only access to FIA Copilot DB) ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Claude API (message generation) ───
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1024

# ─── WhatsApp (choose one provider) ───
WHATSAPP_PROVIDER=cloud_api

# Meta Cloud API
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Twilio (alternative)
# WHATSAPP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Engine behavior ───
INACTIVITY_THRESHOLD_DAYS=5
COLD_LEAD_THRESHOLD_DAYS=15
CELEBRATION_DELAY_MINUTES=30
POST_DIAGNOSTIC_DELAY_MINUTES=10
FIA_APP_BASE_URL=https://fiacopilot.com
MAX_MESSAGES_PER_USER_PER_DAY=2

# ─── Scheduler ───
CRON_DETECTORS=*/15 * * * *
CRON_SPONSOR_REPORT=0 9 * * 1

# ─── Logging ───
LOG_LEVEL=info
